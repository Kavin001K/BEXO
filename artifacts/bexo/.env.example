# Copy to `.env` or `.env.local` (both are gitignored).
# Dashboard → Settings → API: Project URL + anon / publishable key

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Use either name (same client key):
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# EXPO_PUBLIC_SUPABASE_KEY=

# Optional: Node API for resume R2 upload + bio routes (LAN IP for physical device, not localhost)
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.x:3000

# Never commit DATABASE_URL or service_role keys — server-side only.
