# Copy to .env and fill in real values. Never commit .env.

# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# API server (Expo uses EXPO_PUBLIC_* for the mobile bundle)
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Static web export (artifacts/bexo/scripts/build.js) — host where bundles are served
EXPO_PUBLIC_DOMAIN=

# n8n — server-side only (artifacts/api-server). Do NOT use EXPO_PUBLIC_ for the webhook URL.
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=

# Google AI (api-server resume / bio routes)
GOOGLE_API_KEY=
GOOGLE_MODEL=
GOOGLE_MODEL_FALLBACK=

# MSG91 WhatsApp OTP (api-server)
MSG91_AUTH_KEY=
MSG91_WHATSAPP_NUMBER=
MSG91_TEMPLATE_NAME=
MSG91_NAMESPACE=

# OTP signing (api-server)
OTP_SECRET=

# Cloudflare R2 (api-server storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
